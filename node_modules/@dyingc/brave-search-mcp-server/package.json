{
  "name": "@dyingc/brave-search-mcp-server",
  "mcpName": "io.github.brave/brave-search-mcp-server",
  "private": false,
  "version": "2.1.2",
  "description": "Brave Search MCP Server: web results, images, videos, rich results, AI summaries, and more.",
  "keywords": [
    "api",
    "brave",
    "mcp",
    "search"
  ],
  "license": "MIT",
  "author": "dyingc",
  "homepage": "https://github.com/dyingc/brave-search-mcp-server",
  "bugs": "https://github.com/dyingc/brave-search-mcp-server/issues",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dyingc/brave-search-mcp-server.git"
  },
  "type": "module",
  "module": "dist/server.js",
  "bin": {
    "brave-search-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "smithery:build": "smithery build",
    "smithery:dev": "smithery dev",
    "prepare": "npm run format && npm run build",
    "watch": "tsc --watch",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "inspector": "npx @modelcontextprotocol/inspector",
    "inspector:http": "npx @modelcontextprotocol/inspector --transport http",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.2",
    "commander": "14.0.2",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@smithery/cli": "2.2.1",
    "@types/express": "5.0.6",
    "@types/node": "24.10.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "prettier": "3.7.4",
    "shx": "0.4.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "formdata-node": "6.0.3",
    "tmp": "0.2.5"
  }
}
